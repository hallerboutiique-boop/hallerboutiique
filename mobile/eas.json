      "android": {
        "buildType": "apk"
      }
    },
    "github-ios": {
      "distribution": "store",
      "credentialsSource": "local",
      "autoIncrement": false
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
